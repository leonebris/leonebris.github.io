<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Приглашение на свидание</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #ffe6f2;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
            text-align: center;
            position: relative;
        }

        /* Фон с котиком */
        #bgCat {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 70vmin;
            height: 70vmin;
            opacity: 0.15;
            transition: opacity 0.5s ease-in-out;
            pointer-events: none; /* Чтобы фон не мешал нажимать кнопки */
            z-index: 1;
        }

        .scene {
            display: none;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(5px);
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(255, 77, 148, 0.2);
            max-width: 450px;
            width: 90%;
            z-index: 10;
        }
        .active {
            display: block;
            animation: fadeIn 0.5s;
        }
        h1 { font-size: 26px; color: #ff4d94; margin-bottom: 25px; }
        
        button {
            background-color: #ffb3d9;
            border: none;
            padding: 14px 24px;
            margin: 8px;
            border-radius: 25px;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            color: #fff;
            font-weight: bold;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        button:hover { 
            background-color: #ff80bf; 
            transform: translateY(-2px);
            box-shadow: 0 6px 10px rgba(0,0,0,0.15);
        }
        
        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }
        .options-grid button { margin: 0; padding: 12px 10px; font-size: 15px; }
        
        input[type="text"] {
            box-sizing: border-box;
            width: 100%;
            padding: 12px;
            border: 2px solid #ffb3d9;
            border-radius: 15px;
            margin-bottom: 15px;
            font-size: 15px;
            outline: none;
            transition: border-color 0.3s;
        }
        input[type="text"]:focus { border-color: #ff4d94; }
        
        #btnYes { transition: transform 0.2s, background-color 0.3s; }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        
        .hearts {
            position: absolute;
            font-size: 28px;
            animation: float 4s linear infinite;
            z-index: 100;
            pointer-events: none;
        }
        @keyframes float {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }
    </style>
</head>
<body>

    <div id="bgCat"></div>

    <div id="scene1" class="scene active">
        <h1>Пойдем на свидание?</h1>
        <button id="btnYes">Да</button>
        <button id="btnNo">Нет</button>
    </div>

    <div id="scene2" class="scene">
        <h1>Что будем кушать? 🍣</h1>
        <div class="options-grid">
            <button onclick="selectOption('food', 'Салатик')">Суши</button>
            <button onclick="selectOption('food', 'Рамен')">Рамен</button>
            <button onclick="selectOption('food', 'Пицца')">Пицца</button>
            <button onclick="selectOption('food', 'Окрошка')">Бургеры</button>
        </div>
        <input type="text" id="customFood" placeholder="Или напиши свой вариант...">
        <button onclick="selectCustomOption('food', 'customFood')">Далее</button>
    </div>

    <div id="scene3" class="scene">
        <h1>Куда пойдем? 🗺️</h1>
        <div class="options-grid">
            <button onclick="selectOption('place', 'Покушоть')">В ресторан</button>
            <button onclick="selectOption('place', 'Парк')">Парк</button>
            <button onclick="selectOption('place', 'В кино')">В кино</button>
            <button onclick="selectOption('place', 'Останемся дома')">Останемся дома</button>
        </div>
        <input type="text" id="customPlace" placeholder="Или напиши свой вариант...">
        <button onclick="selectCustomOption('place', 'customPlace')">Далее</button>
    </div>

    <div id="scene4" class="scene">
        <h1>А чем перекусим? 🍦</h1>
        <div class="options-grid">
            <button onclick="selectOption('snack', 'Мороженое')">Мороженое</button>
            <button onclick="selectOption('snack', 'Попкорн')">Попкорн</button>
            <button onclick="selectOption('snack', 'Сладкая вата')">Сладкая вата</button>
            <button onclick="selectOption('snack', 'Фрукты')">Фрукты</button>
        </div>
        <input type="text" id="customSnack" placeholder="Или напиши свой вариант...">
        <button onclick="selectCustomOption('snack', 'customSnack')">Далее</button>
    </div>

    <div id="scene5" class="scene">
        <h1>Насколько активно? 🏃‍♀️</h1>
        <div class="options-grid">
            <button onclick="selectOption('activity', 'Хочу бегать и прыгать')">Хочу бегать и прыгать</button>
            <button onclick="selectOption('activity', 'Хочу походить')">Хочу походить</button>
            <button onclick="selectOption('activity', 'Пипися болит')">Пипися болит 😭</button>
            <button onclick="selectOption('activity', 'Хочу много кушать')">Хочу много кушать</button>
        </div>
        <input type="text" id="customActivity" placeholder="Или напиши свой вариант...">
        <button onclick="selectCustomOption('activity', 'customActivity')">Завершить</button>
    </div>

    <div id="scene6" class="scene">
        <h1>Спасибо, что согласилась! ❤️</h1>
        <p>В 9:00 будем ехать 😘.</p>
        <p>Жду с нетерпением!</p>
    </div>

   <script>
        // --- НАСТРОЙКИ TELEGRAM БОТА ---
        const BOT_TOKEN = '8676627438:AAHTqdyaBr2jnfs1DjXFuqngt0McJhq5bJw'; 
        const CHAT_ID = '696380411';
        // -------------------------------

        let yesCount = 0;
        let answers = { food: '', place: '', snack: '', activity: '' };

        const btnYes = document.getElementById('btnYes');
        const btnNo = document.getElementById('btnNo');

        // --- ГЕНЕРАЦИЯ ФОНОВЫХ КОТИКОВ ---
        const catBase = `
            <path d="M50 80 L 30 20 L 90 60 Z" fill="#fff" stroke="#ff80bf" stroke-width="6" stroke-linejoin="round"/>
            <path d="M150 80 L 170 20 L 110 60 Z" fill="#fff" stroke="#ff80bf" stroke-width="6" stroke-linejoin="round"/>
            <circle cx="100" cy="110" r="70" fill="#fff" stroke="#ff80bf" stroke-width="6"/>
            <path d="M30 100 L 5 95 M 30 115 L 0 115 M 30 130 L 5 135" stroke="#ff80bf" stroke-width="4" stroke-linecap="round"/>
            <path d="M170 100 L 195 95 M 170 115 L 200 115 M 170 130 L 195 135" stroke="#ff80bf" stroke-width="4" stroke-linecap="round"/>
        `;
        const catFaces = [
            `<circle cx="75" cy="100" r="6" fill="#ff80bf" /><circle cx="125" cy="100" r="6" fill="#ff80bf" /><path d="M95 120 Q 100 125 105 120" stroke="#ff80bf" stroke-width="4" stroke-linecap="round" fill="none"/><path d="M100 115 L 100 120" stroke="#ff80bf" stroke-width="4" stroke-linecap="round"/>`,
            `<path d="M65 100 Q 75 90 85 100" stroke="#ff80bf" stroke-width="5" stroke-linecap="round" fill="none"/><path d="M115 100 Q 125 90 135 100" stroke="#ff80bf" stroke-width="5" stroke-linecap="round" fill="none"/><path d="M95 120 Q 100 125 105 120" stroke="#ff80bf" stroke-width="4" stroke-linecap="round" fill="none"/><path d="M100 115 L 100 120" stroke="#ff80bf" stroke-width="4" stroke-linecap="round"/>`,
            `<circle cx="75" cy="100" r="6" fill="#ff80bf" /><circle cx="125" cy="100" r="6" fill="#ff80bf" /><circle cx="100" cy="120" r="5" fill="none" stroke="#ff80bf" stroke-width="4"/>`,
            `<path d="M65 100 Q 75 90 85 100" stroke="#ff80bf" stroke-width="5" stroke-linecap="round" fill="none"/><circle cx="125" cy="100" r="6" fill="#ff80bf" /><path d="M95 115 Q 100 125 105 115 Z" fill="#ff80bf" stroke="#ff80bf" stroke-width="2"/>`,
            `<circle cx="75" cy="100" r="6" fill="#ff80bf" /><path d="M115 100 L 125 90 L 135 100" stroke="#ff80bf" stroke-width="5" stroke-linecap="round" fill="none" stroke-linejoin="round"/><path d="M95 120 Q 100 125 105 120" stroke="#ff80bf" stroke-width="4" stroke-linecap="round" fill="none"/><path d="M100 115 L 100 120" stroke="#ff80bf" stroke-width="4" stroke-linecap="round"/>`,
            `<path d="M65 100 L 75 90 L 85 100" stroke="#ff80bf" stroke-width="5" stroke-linecap="round" fill="none" stroke-linejoin="round"/><path d="M115 100 L 125 90 L 135 100" stroke="#ff80bf" stroke-width="5" stroke-linecap="round" fill="none" stroke-linejoin="round"/><path d="M90 115 Q 100 135 110 115 Z" fill="#ff80bf"/>`
        ];

        function updateCat(sceneNumber) {
            const catContainer = document.getElementById('bgCat');
            catContainer.style.opacity = 0; 
            setTimeout(() => {
                const face = catFaces[(sceneNumber - 1) % catFaces.length];
                catContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">${catBase}${face}</svg>`;
                catContainer.style.opacity = 0.15; 
            }, 500); 
        }

        updateCat(1);

        // --- ЛОГИКА КНОПОК ---
        btnNo.addEventListener('click', () => {
            btnNo.style.display = 'none';
        });

        btnYes.addEventListener('click', () => {
            yesCount++;
            if (yesCount < 5) {
                // ИСПРАВЛЕНИЕ: Вытаскиваем кнопку в корень сайта (body), чтобы сбросить локальную систему координат
                if (btnYes.parentElement !== document.body) {
                    document.body.appendChild(btnYes);
                }

                const margin = 100;
                
                const maxX = window.innerWidth - btnYes.clientWidth - margin;
                const maxY = window.innerHeight - btnYes.clientHeight - margin;

                const randomX = margin + Math.floor(Math.random() * Math.max(0, maxX - margin));
                const randomY = margin + Math.floor(Math.random() * Math.max(0, maxY - margin));

                btnYes.style.position = 'fixed';
                btnYes.style.left = randomX + 'px';
                btnYes.style.top = randomY + 'px';
                btnYes.style.transform = `scale(${1 - yesCount * 0.15})`;
            } else {
                // ИСПРАВЛЕНИЕ: Прячем вытащенную кнопку перед переходом
                btnYes.style.display = 'none';
                showScene(2);
            }
        });

        function selectOption(category, value) {
            answers[category] = value;
            nextSceneLogic(category);
        }

        function selectCustomOption(category, inputId) {
            const val = document.getElementById(inputId).value.trim();
            answers[category] = val ? val : "Свой вариант не написан";
            nextSceneLogic(category);
        }

        function nextSceneLogic(category) {
            if (category === 'food') showScene(3);
            else if (category === 'place') showScene(4);
            else if (category === 'snack') showScene(5);
            else if (category === 'activity') finishSurvey();
        }

        function showScene(number) {
            document.querySelectorAll('.scene').forEach(el => el.classList.remove('active'));
            document.getElementById('scene' + number).classList.add('active');
            updateCat(number); 
        }

        function finishSurvey() {
            showScene(6);
            createHearts();
            sendToTelegram();
        }

        function createHearts() {
            setInterval(() => {
                const heart = document.createElement('div');
                heart.classList.add('hearts');
                heart.innerHTML = '💖';
                heart.style.left = Math.random() * 100 + 'vw';
                heart.style.animationDuration = Math.random() * 3 + 2 + 's';
                document.body.appendChild(heart);
                setTimeout(() => heart.remove(), 5000);
            }, 250);
        }

        function sendToTelegram() {
            if (BOT_TOKEN === 'ТВОЙ_ТОКЕН_БОТА') {
                console.log('Результаты опроса (токен не настроен):', answers);
                return;
            }

            const message = `🎉 Она согласилась!\n\n🍣 Еда: ${answers.food}\n🗺️ Место: ${answers.place}\n🍦 Перекус: ${answers.snack}\n🏃‍♀️ Активность: ${answers.activity}`;
            const url = `https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`;

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    chat_id: CHAT_ID,
                    text: message
                })
            }).catch(error => console.error('Ошибка отправки:', error));
        }
    </script>
</body>
</html>
